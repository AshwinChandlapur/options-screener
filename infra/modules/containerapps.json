    "placeholderJobImage": "mcr.microsoft.com/k8se/quickstart-jobs:latest",
    "envName": "[format('cae-narrative-{0}', parameters('nameSuffix'))]"
  },
  "resources": [
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[variables('envName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
