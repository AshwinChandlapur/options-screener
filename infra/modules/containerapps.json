    },
    {
      "condition": "[not(empty(parameters('keyVaultId')))]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(parameters('keyVaultId'), 'job-ingestor', variables('roleSecretsUser'))]",
      "properties": {
        "roleDefinitionId": "[variables('roleSecretsUser')]",
        "principalId": "[reference(resourceId('Microsoft.App/containerApps', 'job-ingestor'), '2024-03-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/containerApps', 'job-ingestor')]"
      ]
    },
    {
      "condition": "[not(empty(parameters('keyVaultId')))]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(parameters('keyVaultId'), 'job-extractor', variables('roleSecretsUser'))]",
      "properties": {
        "roleDefinitionId": "[variables('roleSecretsUser')]",
        "principalId": "[reference(resourceId('Microsoft.App/jobs', 'job-extractor'), '2024-03-01', 'full').identity.principalId]",
