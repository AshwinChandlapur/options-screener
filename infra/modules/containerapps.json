    },
    {
      "condition": "[not(empty(parameters('keyVaultId')))]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(parameters('keyVaultId'), 'job-classifier', variables('roleSecretsUser'))]",
      "properties": {
