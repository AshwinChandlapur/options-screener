    },
    {
      "type": "Microsoft.App/jobs",
      "apiVersion": "2024-03-01",
      "name": "job-aggregator",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
