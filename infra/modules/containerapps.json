                  "value": "[parameters('blobAccountName')]"
                },
                {
                  "name": "LOG_LEVEL",
                  "value": "INFO"
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 2
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', variables('envName'))]"
