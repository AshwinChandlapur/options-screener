          "replicaTimeout": 120,
          "scheduleTriggerConfig": {
            "cronExpression": "*/5 * * * *",
            "parallelism": 1,
            "replicaCompletionCount": 1
          },
          "registries": []
        },
        "template": {
          "containers": [
            {
              "name": "extractor",
              "image": "[variables('placeholderJobImage')]",
              "resources": {
                "cpu": "[json('0.25')]",
                "memory": "0.5Gi"
              },
              "env": [
                {
                  "name": "KEYVAULT_URI",
                  "value": "[parameters('keyVaultUri')]"
                },
                {
                  "name": "EVENT_HUB_NAMESPACE",
                  "value": "[parameters('eventHubNamespaceFqdn')]"
                },
                {
                  "name": "COSMOS_ENDPOINT",
                  "value": "[parameters('cosmosEndpoint')]"
                },
                {
                  "name": "LOG_LEVEL",
                  "value": "INFO"
                }
              ]
            }
          ]
        }
      },
      "dependsOn": [
