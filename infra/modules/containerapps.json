      "value": "[reference(resourceId('Microsoft.App/containerApps', 'job-ingestor'), '2024-03-01', 'full').identity.principalId]"
    },
    "extractorJobPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/jobs', 'job-extractor'), '2024-03-01', 'full').identity.principalId]"
    },
    "aggregatorJobPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/jobs', 'job-aggregator'), '2024-03-01', 'full').identity.principalId]"
    },
    "classifierJobPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/jobs', 'job-classifier'), '2024-03-01', 'full').identity.principalId]"
