        "configuration": {
          "triggerType": "Schedule",
          "replicaTimeout": 120,
          "scheduleTriggerConfig": {
            "cronExpression": "*/15 * * * *",
            "parallelism": 1,
            "replicaCompletionCount": 1
          },
          "registries": []
        },
        "template": {
          "containers": [
            {
              "name": "aggregator",
              "image": "[variables('placeholderJobImage')]",
              "resources": {
                "cpu": "[json('0.25')]",
                "memory": "0.5Gi"
              },
              "env": [
                {
                  "name": "COSMOS_ENDPOINT",
                  "value": "[parameters('cosmosEndpoint')]"
                },
                {
                  "name": "LOG_LEVEL",
                  "value": "INFO"
