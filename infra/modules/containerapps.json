      "apiVersion": "2024-03-01",
      "name": "job-classifier",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('envName'))]",
        "configuration": {
          "triggerType": "Schedule",
          "replicaTimeout": 1500,
          "scheduleTriggerConfig": {
            "cronExpression": "*/30 * * * *",
            "parallelism": 1,
            "replicaCompletionCount": 1
          },
          "registries": []
        },
        "template": {
          "containers": [
            {
              "name": "classifier",
              "image": "[variables('placeholderJobImage')]",
              "resources": {
                "cpu": "[json('0.5')]",
                "memory": "1.0Gi"
              },
              "env": [
                {
                  "name": "KEYVAULT_URI",
                  "value": "[parameters('keyVaultUri')]"
                },
                {
                  "name": "COSMOS_ENDPOINT",
                  "value": "[parameters('cosmosEndpoint')]"
